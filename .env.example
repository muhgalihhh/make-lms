# Pare EDUHUB LMS Configuration

# Application
VITE_APP_NAME="Pare EDUHUB"
VITE_APP_URL="http://localhost:3000"
VITE_APP_ENV="development"

# Tawk.to Live Chat Configuration
VITE_TAWK_PROPERTY_ID="your_tawk_property_id"
VITE_TAWK_WIDGET_ID="your_tawk_widget_id"

# Midtrans Payment Gateway Configuration
VITE_MIDTRANS_CLIENT_KEY="your_midtrans_client_key"
VITE_MIDTRANS_MERCHANT_ID="your_midtrans_merchant_id"
VITE_MIDTRANS_SERVER_KEY="your_midtrans_server_key"
VITE_MIDTRANS_ENVIRONMENT="sandbox" # sandbox or production

# Weather API Configuration (Optional)
VITE_WEATHER_API_KEY="your_weather_api_key"
VITE_WEATHER_API_URL="https://api.openweathermap.org/data/2.5"

# Contact Information
VITE_CONTACT_PHONE="+6281234567890"
VITE_CONTACT_EMAIL="info@pareeduhub.com"
VITE_CONTACT_WHATSAPP="+6281234567890"

# Social Media Links
VITE_FACEBOOK_URL="https://facebook.com/pareeduhub"
VITE_INSTAGRAM_URL="https://instagram.com/pareeduhub"
VITE_LINKEDIN_URL="https://linkedin.com/company/pareeduhub"
VITE_YOUTUBE_URL="https://youtube.com/pareeduhub"

# External Services
VITE_TIKET_COM_AFFILIATE_ID="your_tiket_affiliate_id"
VITE_GOOGLE_ANALYTICS_ID="your_ga_id"

# Feature Flags
VITE_ENABLE_WEATHER_WIDGET="true"
VITE_ENABLE_LIVE_CHAT="true"
VITE_ENABLE_PAYMENT="true"
VITE_ENABLE_HOTEL_BOOKING="true"

# API Endpoints
VITE_API_BASE_URL="http://localhost:8000/api"
VITE_UPLOAD_URL="http://localhost:8000/storage"

# Security
VITE_CSRF_TOKEN="your_csrf_token"
VITE_APP_KEY="your_app_key"
